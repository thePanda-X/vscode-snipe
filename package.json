{
  "name": "vscode-snipe",
  "displayName": "Snipe - AI Code Assistant",
  "description": "AI-powered code implementation using opencode - fill in functions and refactor selections without losing your flow",
  "version": "0.0.1",
  "publisher": "thePanda-X",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "opencode",
    "code generation",
    "refactoring",
    "productivity"
  ],
  "activationEvents": [
    "onCommand:snipe.fillInFunction",
    "onCommand:snipe.visualSelection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "snipe.fillInFunction",
        "title": "Snipe: Fill In Function"
      },
      {
        "command": "snipe.visualSelection",
        "title": "Snipe: Implement Selection"
      },
      {
        "command": "snipe.stopAllRequests",
        "title": "Snipe: Stop All Requests"
      },
      {
        "command": "snipe.viewLogs",
        "title": "Snipe: View Logs"
      }
    ],
    "keybindings": [
      {
        "command": "snipe.fillInFunction",
        "key": "ctrl+alt+9",
        "mac": "cmd+alt+9",
        "when": "editorTextFocus"
      },
      {
        "command": "snipe.visualSelection",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorHasSelection"
      },
      {
        "command": "snipe.stopAllRequests",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Snipe",
      "properties": {
        "snipe.opencodePath": {
          "type": "string",
          "default": "opencode",
          "description": "Path to the opencode executable"
        },
        "snipe.mdFiles": {
          "type": "array",
          "default": ["AGENT.md"],
          "description": "Context markdown files to look for in the directory hierarchy"
        },
        "snipe.includeFileTree": {
          "type": "boolean",
          "default": false,
          "description": "Include project file tree in prompts"
        },
        "snipe.fileTreeDepth": {
          "type": "number",
          "default": 2,
          "description": "Max depth for file tree"
        },
        "snipe.showDiffBeforeApply": {
          "type": "boolean",
          "default": false,
          "description": "Show diff view before applying changes"
        },
        "snipe.logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "error",
          "description": "Log verbosity level"
        },
        "snipe.cancelOnNewRequest": {
          "type": "boolean",
          "default": true,
          "description": "Auto-cancel running request when a new one is started"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
